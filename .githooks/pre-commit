#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Allow cherry-picks and reverts (recovery operations)
if [ -f "$repo_root/.git/CHERRY_PICK_HEAD" ] || [ -f "$repo_root/.git/REVERT_HEAD" ]; then
  exit 0
fi

# Check if any staged changes touch conker/src/ or conker/include/
staged="$(git diff --cached --name-only --diff-filter=ACMR -- conker/src/ conker/include/ 2>/dev/null || true)"
if [ -z "$staged" ]; then
  exit 0
fi

# Protected source is staged — MUST verify full ROM build passes
echo "🔨 Protected source staged — running full ROM verification..." >&2
echo "$staged" >&2

BUILD_OUTPUT=$(docker run --rm --platform linux/amd64 \
  -v "$repo_root:/conker" -w /conker \
  conker-build-min-amd64 \
  bash -lc 'rm -f conker/build/conker.us.ok conker/build/conker.us.bin && make -C conker -j$(nproc) 2>&1 | tail -5')

if echo "$BUILD_OUTPUT" | grep -q "conker.us.bin: OK"; then
  echo "✅ ROM SHA verified — commit allowed" >&2
  exit 0
fi

echo "⛔ ROM SHA FAILED — commit blocked" >&2
echo "$BUILD_OUTPUT" >&2
echo "" >&2
echo "The staged source changes do not produce a matching ROM." >&2
echo "Fix the code or revert with: git checkout -- conker/src/ conker/include/" >&2
exit 1
